#! /bin/sh

chosen=$(printf "яАС  Power Off\nяАЮ  Restart\nяЖЖ  Suspend\nяЛЬ  Hibernate\nябВ  Log Out\nяАг  Lock" | rofi -dmenu -i -theme-str '@import "power.rasi"')

case "$chosen" in
	"яАС  Power Off") poweroff ;;
	"яАЮ  Restart") reboot ;;
	"яЖЖ  Suspend") xfce4-session-logout --suspend;;
	"яЛЬ  Hibernate") xfce4-session-logout --hibernate;;
	"ябВ  Log Out") xfce4-session-logout --logout;;
	"яАг  Lock") xfce4-screensaver-command --lock;;
	*) exit 1 ;;
esac
